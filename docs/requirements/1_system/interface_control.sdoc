    TYPE: String
    REQUIRED: True
- TAG: TEXT
  FIELDS:
  - TITLE: UID
    TYPE: String
    REQUIRED: False
  - TITLE: STATEMENT
    TYPE: String
    REQUIRED: True
- TAG: INTERFACE_CONTROL
  PROPERTIES:
    PREFIX: IC-
    VIEW_STYLE: Narrative
  FIELDS:
